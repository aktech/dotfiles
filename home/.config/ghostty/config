# Ghostty config - https://ghostty.org/docs/config
font-family = Cascadia Code
font-size = 15
font-feature = calt
font-feature = liga
theme = TokyoNight Night
keybind = shift+enter=text:\x1b\r
copy-on-select = clipboard

# This lets us switch between different tmux panes via option + left/right arrow
keybind = alt+left=text:\x1b[1;3D
keybind = alt+right=text:\x1b[1;3C
keybind = cmd+left=previous_tab
keybind = cmd+right=next_tab
