__conda_setup="$('/Users/aktech/miniconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/Users/aktech/miniconda3/etc/profile.d/conda.sh" ]; then
        . "/Users/aktech/miniconda3/etc/profile.d/conda.sh"
    else
        export PATH="/Users/aktech/miniconda3/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<


